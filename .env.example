# Claude Swarm — Environment Configuration
# Copy to .env and fill in production values

# Redis
SWARM_REDIS_HOST=127.0.0.1
SWARM_REDIS_PORT=6379
SWARM_REDIS_PASSWORD=
SWARM_REDIS_DB=0
SWARM_REDIS_SKIP_CHECK=

# Backend engine (redis | auto)
SWARM_BACKEND=auto

# Fleet hosts
MINIBOSS_HOST=127.0.0.1
GIGA_HOST=127.0.0.1
